{
    "name": "2amdmedia/pimuscu",
    "description": "Hub SaaS PrestaShop — sync, scoring SEO et optimisation IA des contenus produits/catégories.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "vlucas/phpdotenv": "^5.6",
        "ramsey/uuid": "^4.7",
        "phpmailer/phpmailer": "^6.9",
        "composer/ca-bundle": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
